        "        \"smb_replicated\": (\n",
        "        x[\"ret\"][x[\"portfolio_size\"] == 1].mean() - \n",
        "            x[\"ret\"][x[\"portfolio_size\"] == 2].mean())})\n",
        "    )\n",
        "    .reset_index()\n",
        ")"
